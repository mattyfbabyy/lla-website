<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Personal Branding For Realtors | Luxury Leasing Academy</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Figtree:wght@400;500;600;700&display=swap" rel="stylesheet">
<style>
:root{--ivory:#FAF6EE;--cream:#F2EADB;--espresso:#2A2018;--espresso-soft:#4A3D30;--gold:#B9892F;--gold-bright:#D4A94E;--amber:#C96F23;--haze:#8C7C68;--white:#FFFDF9}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Figtree',sans-serif;background:var(--ivory);color:var(--espresso);line-height:1.6;font-size:17px}
h1,h2,h3,.serif{font-family:'Fraunces',serif;font-weight:500;line-height:1.12;letter-spacing:-0.01em}
img{max-width:100%;display:block}
a{text-decoration:none;color:inherit}
.wrap{max-width:1160px;margin:0 auto;padding:0 28px}
.horizon{height:2px;border:none;background:linear-gradient(90deg,transparent,var(--gold) 25%,var(--amber) 55%,transparent 90%);opacity:.7;max-width:1160px;margin:0 auto}
nav{position:sticky;top:0;z-index:50;background:rgba(250,246,238,.92);backdrop-filter:blur(10px);border-bottom:1px solid rgba(185,137,47,.18)}
.nav-inner{display:flex;align-items:center;justify-content:space-between;padding:14px 28px;max-width:1240px;margin:0 auto}
.nav-logo{display:flex;align-items:center;gap:11px}
.nav-logo img{height:46px;width:auto}
.nav-wordmark{font-family:'Fraunces',serif;font-weight:600;font-size:19px;color:var(--espresso);line-height:1.1}
.nav-links{display:flex;gap:30px;align-items:center;font-weight:500;font-size:15px}
.nav-links a{color:var(--espresso-soft);transition:color .2s}
.nav-links a:hover{color:var(--gold)}
.nav-login{font-size:14px;color:var(--haze)!important}
.btn{display:inline-block;padding:13px 28px;border-radius:999px;font-weight:600;font-size:15.5px;transition:transform .25s,box-shadow .25s;cursor:pointer;border:none}
.btn-gold{background:linear-gradient(120deg,var(--gold),var(--gold-bright));color:#fff;box-shadow:0 6px 18px rgba(185,137,47,.32)}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 10px 26px rgba(185,137,47,.42)}
.btn-ghost{border:1.5px solid var(--gold);color:var(--gold)}
.btn-ghost:hover{background:rgba(185,137,47,.08)}
.btn-dark{background:var(--espresso);color:var(--ivory)}
.btn-dark:hover{transform:translateY(-2px)}
.nav-burger{display:none;background:none;border:none;cursor:pointer;padding:8px;flex-direction:column;gap:5px}
.nav-burger span{display:block;width:24px;height:2.5px;background:var(--espresso);border-radius:2px;transition:transform .3s,opacity .3s}
.nav-burger.open span:nth-child(1){transform:translateY(7.5px) rotate(45deg)}
.nav-burger.open span:nth-child(2){opacity:0}
.nav-burger.open span:nth-child(3){transform:translateY(-7.5px) rotate(-45deg)}
.mobile-menu{display:none;flex-direction:column;gap:4px;padding:10px 28px 26px;border-top:1px solid rgba(185,137,47,.18)}
.mobile-menu.open{display:flex}
.mobile-menu a{padding:13px 0;font-weight:600;font-size:17px;border-bottom:1px solid rgba(185,137,47,.12)}
.mobile-menu .mm-login{color:var(--haze)}
.mobile-menu .btn{margin-top:16px;text-align:center;border-bottom:none}
.eyebrow{font-size:12.5px;font-weight:700;letter-spacing:.22em;text-transform:uppercase;color:var(--gold);margin-bottom:20px}
.price-ph{display:inline-block;background:rgba(201,111,35,.12);border:1px dashed var(--amber);border-radius:8px;padding:0 8px;color:var(--amber);font-weight:700;font-size:.9em}
.section{padding:92px 0}
.section-head{max-width:720px;margin-bottom:54px}
.section-head h2{font-size:clamp(30px,3.6vw,44px);margin-bottom:16px}
.section-head p{color:var(--espresso-soft);font-size:18px}
.card{background:var(--white);border:1px solid rgba(185,137,47,.18);border-radius:18px;padding:38px 32px;position:relative;transition:transform .3s,box-shadow .3s}
.card:hover{transform:translateY(-6px);box-shadow:0 22px 44px rgba(42,32,24,.12)}
.cards3{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
.band{background:var(--espresso);color:var(--ivory);padding:96px 0;position:relative;overflow:hidden}
.band .glow{position:absolute;width:560px;height:560px;border-radius:50%;background:radial-gradient(circle,rgba(201,111,35,.25),transparent 65%);top:-200px;right:-120px}
.band h2{font-size:clamp(28px,3.6vw,42px);margin-bottom:18px}
.band h2 em{font-style:italic;color:var(--gold-bright)}
.band p{color:#CBBFAE;font-size:18px}
.band p strong{color:var(--gold-bright)}
.final{background:var(--espresso);color:var(--ivory);padding:110px 0;text-align:center;position:relative;overflow:hidden}
.final .glow{position:absolute;width:700px;height:380px;left:50%;transform:translateX(-50%);bottom:-220px;background:radial-gradient(ellipse,rgba(212,169,78,.3),transparent 65%)}
.final h2{font-size:clamp(34px,4.4vw,54px);margin-bottom:18px;position:relative}
.final p{color:#CBBFAE;font-size:19px;margin-bottom:38px;position:relative}
.final .micro{font-size:14.5px;margin-top:22px;color:#A4937D}
.final .micro a{color:var(--gold-bright);text-decoration:underline}
footer{background:#211911;color:#B5A893;padding:64px 0 40px;font-size:14.5px}
.foot-grid{display:grid;grid-template-columns:1.4fr 1fr 1fr 1fr;gap:40px;margin-bottom:44px}
.foot-grid h4{color:var(--ivory);font-size:13px;letter-spacing:.16em;text-transform:uppercase;margin-bottom:16px}
.foot-grid a{display:block;margin-bottom:10px;transition:color .2s}
.foot-grid a:hover{color:var(--gold-bright)}
.foot-tag{font-family:'Fraunces',serif;font-style:italic;color:var(--ivory);font-size:19px;margin:14px 0 6px;max-width:280px;line-height:1.4}
.foot-logo img{height:46px;width:auto}
.foot-bottom{border-top:1px solid rgba(185,137,47,.2);padding-top:26px;display:flex;justify-content:space-between;gap:12px;font-size:13px}
.rv{opacity:0;transform:translateY(26px);transition:opacity .8s ease,transform .8s ease}
.rv.in{opacity:1;transform:none}
@media (prefers-reduced-motion:reduce){.rv{opacity:1;transform:none;transition:none}html{scroll-behavior:auto}}
/* catalog */
.club-banner{background:var(--espresso);color:var(--ivory);border-radius:18px;padding:26px 32px;display:flex;align-items:center;justify-content:space-between;gap:20px;flex-wrap:wrap;margin-bottom:64px}
.club-banner strong{color:var(--gold-bright);font-family:'Fraunces',serif;font-size:20px;font-weight:600}
.club-banner p{color:#CBBFAE;font-size:15.5px;margin-top:4px}
.tier{margin-bottom:64px}
.tier-label{display:flex;align-items:baseline;gap:16px;margin-bottom:26px}
.tier-label h3{font-size:27px}
.tier-label span{font-size:12.5px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--amber)}
.course-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:26px}
.course-grid.two{grid-template-columns:repeat(2,1fr)}
.ccard{background:var(--white);border:1px solid rgba(185,137,47,.18);border-radius:18px;overflow:hidden;display:flex;flex-direction:column;transition:transform .3s,box-shadow .3s}
.ccard:hover{transform:translateY(-6px);box-shadow:0 22px 44px rgba(42,32,24,.12)}
.ccard-img{background:var(--cream);padding:26px;display:flex;justify-content:center}
.ccard-img img{height:215px;width:auto}
.ccard-body{padding:26px 28px 30px;display:flex;flex-direction:column;flex:1}
.ccard-meta{font-size:12px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--haze);margin-bottom:10px}
.ccard-meta b{color:var(--gold)}
.ccard h3{font-size:21px;margin-bottom:8px}
.ccard p{color:var(--espresso-soft);font-size:15px;flex:1;margin-bottom:18px}
.ccard-foot{display:flex;justify-content:space-between;align-items:center}
.ccard-foot a{color:var(--gold);font-weight:600;font-size:15px}
.ccard-foot a:hover{text-decoration:underline}
/* course detail */
.chero{padding:76px 0 70px}
.chero-grid{display:grid;grid-template-columns:.85fr 1.15fr;gap:64px;align-items:center}
.chero-img{background:var(--cream);border-radius:24px;padding:40px;display:flex;justify-content:center;box-shadow:0 26px 60px rgba(42,32,24,.12)}
.chero h1{font-size:clamp(34px,4.2vw,52px);margin-bottom:18px}
.chero .promise{font-size:19px;color:var(--espresso-soft);margin-bottom:30px}
.cmeta{display:flex;gap:12px;margin-bottom:20px;flex-wrap:wrap}
.badge{font-size:12.5px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;border:1px solid rgba(185,137,47,.45);color:var(--gold);border-radius:999px;padding:6px 14px}
.cprice{display:flex;align-items:center;gap:18px;flex-wrap:wrap}
.cprice .alt{font-size:14.5px;color:var(--haze)}
.cprice .alt a{color:var(--gold);font-weight:600;text-decoration:underline}
.bullets{list-style:none}
.bullets li{padding:11px 0 11px 34px;position:relative;font-size:16.5px;color:var(--espresso-soft);border-bottom:1px solid rgba(185,137,47,.12)}
.bullets li:last-child{border-bottom:none}
.bullets li::before{content:"\2713";position:absolute;left:0;color:var(--gold);font-weight:700}
.modlist{counter-reset:mod;list-style:none;max-width:760px}
.modlist li{counter-increment:mod;background:var(--white);border:1px solid rgba(185,137,47,.18);border-radius:14px;padding:20px 24px 20px 74px;margin-bottom:12px;font-weight:600;font-size:16.5px;position:relative}
.modlist li::before{content:counter(mod,decimal-leading-zero);position:absolute;left:24px;top:50%;transform:translateY(-50%);font-family:'Fraunces',serif;font-size:21px;color:var(--gold);font-weight:600}
.dgrid{display:flex;flex-wrap:wrap;gap:11px}
.dpill{font-size:14px;font-weight:600;border:1px solid rgba(185,137,47,.4);color:var(--espresso-soft);border-radius:999px;padding:9px 18px;background:var(--white)}
.dpill::before{content:"\2713  ";color:var(--gold);font-weight:700}
.soon{font-size:15.5px;color:var(--haze);font-style:italic}
/* ebook + thanks */
.hero-split{padding:84px 0 76px}
.hs-grid{display:grid;grid-template-columns:1.15fr .85fr;gap:64px;align-items:center}
.hs-grid h1{font-size:clamp(36px,4.6vw,56px);margin-bottom:22px}
.hs-grid h1 em{font-style:italic;color:var(--gold)}
.hs-grid .sub{font-size:19px;color:var(--espresso-soft);margin-bottom:32px}
.book-shot{display:flex;justify-content:center}
.book-shot img{max-height:480px;width:auto;filter:drop-shadow(0 30px 50px rgba(42,32,24,.25))}
.optform{display:flex;gap:12px;max-width:520px;flex-wrap:wrap}
.optform input{flex:1;min-width:220px;padding:15px 22px;border-radius:999px;border:1.5px solid rgba(185,137,47,.4);background:var(--white);font-family:inherit;font-size:16px;outline:none;color:var(--espresso)}
.optform input:focus{border-color:var(--gold)}
.optform .btn{padding:15px 30px}
.form-micro{font-size:13.5px;color:var(--haze);margin-top:12px}
.center{text-align:center}
.center .section-head{margin-left:auto;margin-right:auto}
.center .optform{margin:0 auto}
/* matty page */
.story{max-width:740px;margin:0 auto}
.story p{font-size:18.5px;color:var(--espresso-soft);margin-bottom:26px}
.story p strong{color:var(--espresso)}
.story .lede{font-size:22px;font-family:'Fraunces',serif;color:var(--espresso);line-height:1.5}
.mhero{padding:84px 0 70px}
.mhero-grid{display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center}
.mhero h1{font-size:clamp(36px,4.6vw,56px);margin-bottom:20px}
.mhero .sub{font-size:19px;color:var(--espresso-soft)}
.arch{border-radius:300px 300px 24px 24px;overflow:hidden;box-shadow:0 30px 70px rgba(42,32,24,.22);position:relative}
.arch::after{content:"";position:absolute;inset:0;background:linear-gradient(180deg,rgba(212,169,78,0) 55%,rgba(201,111,35,.22));pointer-events:none}
.arch img{width:100%;height:520px;object-fit:cover}
.stats{display:flex;gap:48px;flex-wrap:wrap}
.stat .num{font-family:'Fraunces',serif;font-size:42px;color:var(--gold);font-weight:600;line-height:1}
.stat .lbl{font-size:13px;letter-spacing:.12em;text-transform:uppercase;color:var(--haze);margin-top:8px;font-weight:600}
.tick{width:42px;height:42px;border-radius:50%;background:linear-gradient(120deg,var(--gold),var(--gold-bright));display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;margin-bottom:22px;font-size:18px}
/* thanks */
.confirm{padding:70px 0 30px;text-align:center}
.confirm h1{font-size:clamp(32px,4.2vw,48px);margin-bottom:16px}
.confirm p{color:var(--espresso-soft);font-size:17.5px;max-width:560px;margin:0 auto}
.tripwire{background:var(--cream)}
.tw-grid{display:grid;grid-template-columns:.8fr 1.2fr;gap:60px;align-items:center}
.anchor-line{font-family:'Fraunces',serif;font-size:22px;margin:26px 0}
.anchor-line .strike{color:var(--haze)}
.anchor-line .pop{color:var(--gold);font-weight:600;font-size:30px}
@media (max-width:900px){
  .cards3,.course-grid,.course-grid.two{grid-template-columns:1fr}
  .chero-grid,.hs-grid,.mhero-grid,.tw-grid{grid-template-columns:1fr;gap:44px}
  .foot-grid{grid-template-columns:1fr 1fr}
  .nav-links{display:none}
  .nav-burger{display:flex}
  .book-shot{order:-1}
}
@media (max-width:600px){
  body{font-size:16px}
  .wrap{padding:0 20px}
  .nav-inner{padding:12px 20px}
  .nav-logo img{height:40px}
  .nav-wordmark{font-size:16px}
  .section{padding:62px 0}
  .band{padding:62px 0}
  .final{padding:76px 0}
  .hero-split,.chero,.mhero{padding:48px 0 54px}
  .optform .btn,.cprice .btn{width:100%;text-align:center}
  .arch img{height:360px}
  .stats{gap:24px}
  .stat .num{font-size:32px}
  .foot-grid{grid-template-columns:1fr;gap:28px}
  .foot-bottom{flex-direction:column;gap:6px}
  .club-banner{padding:22px 22px}
  .ccard-img img{height:180px}
}
</style>
</head>
<body>
<nav>
  <div class="nav-inner">
    <a class="nav-logo" href="index.html"><img src="img/crest.png" alt="Luxury Leasing Academy crest"><span class="nav-wordmark">Luxury Leasing Academy</span></a>
    <button class="nav-burger" id="burger" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
    <div class="nav-links"><a href="courses.html">Courses</a><a href="club.html">Elite Club</a><a href="ebook.html">Free E-Book</a><a href="meet-matty.html">Meet Matty</a><a href="https://portal.luxuryleasingacademy.com" class="nav-login">Student Login</a><a href="club.html" class="btn btn-gold">Join the Club</a></div>
  </div>
  <div class="mobile-menu" id="mobileMenu"><a href="courses.html">Courses</a><a href="club.html">Elite Club</a><a href="ebook.html">Free E-Book</a><a href="meet-matty.html">Meet Matty</a><a href="https://portal.luxuryleasingacademy.com" class="mm-login">Student Login</a><a href="club.html" class="btn btn-gold">Join the Club</a></div>
</nav>
<header class="chero">
  <div class="wrap chero-grid">
    <div class="chero-img rv in"><img src="img/c6-mockup.png" alt="Personal Branding For Realtors course box"></div>
    <div class="rv in">
      <div class="cmeta"><span class="badge">Course 6</span><span class="badge">Professional</span><span class="badge">39 lessons</span></div>
      <h1>Personal Branding For Realtors</h1>
      <p class="promise">Build a brand that attracts clients instead of chasing them. Most agents never think about their brand until it's already working against them.</p>
      <div class="cprice">
        <a href="#" class="btn btn-gold" style="font-size:16.5px;padding:15px 34px">Enroll Now &middot;&nbsp;<span class="price-ph">$PRICE</span></a>
        <span class="alt">Or get all 9 courses in <a href="club.html">the Club</a> for <span class="price-ph">$PRICE</span>/mo</span>
      </div>
    </div>
  </div>
</header>
<hr class="horizon">
<section class="section" style="padding-bottom:50px">
  <div class="wrap">
    <div class="section-head rv"><div class="eyebrow">Who This Is For</div><h2>This course is built for you if</h2></div>
    <ul class="bullets rv" style="max-width:700px"><li>You're invisible online and clients have no reason to remember you</li><li>Your profile looks like every other agent's profile</li><li>You're ready to become the name people think of first</li></ul>
  </div>
</section>
<section class="section" style="padding-top:50px;padding-bottom:50px">
  <div class="wrap">
    <div class="section-head rv"><div class="eyebrow">The Curriculum</div><h2>What you'll learn</h2><p>10 modules, 39 lessons. Slide-based video lessons you can take at your own pace.</p></div>
    <ol class="modlist rv"><li>Welcome</li><li>The Power of a Personal Brand</li><li>Defining Your Brand Identity</li><li>The Brand Audit</li><li>Creating Compelling Content</li><li>Engaging Your Audience & Community</li><li>Partnerships & Influencers</li><li>Measuring & Optimizing</li><li>Sustaining & Growing Your Brand</li><li>Your 30-Day Action Plan</li></ol>
  </div>
</section>
<section class="section" style="padding-top:50px">
  <div class="wrap">
    <div class="section-head rv"><div class="eyebrow">The Toolkit</div><h2>Your deliverables</h2><p>11 done-for-you tools included. These aren't worksheets for the sake of worksheets; they're the actual systems used in the field.</p></div>
    <div class="dgrid rv"><span class="dpill">30-Day Personal Branding Action Plan</span><span class="dpill">Brand Audit Checklist</span><span class="dpill">Brand Clarity Workshop</span><span class="dpill">Brand Growth Tracker</span><span class="dpill">Brand Video Script Templates</span><span class="dpill">Client Avatar Deep Dive</span><span class="dpill">Content Pillar Builder</span><span class="dpill">Personal Bio Builder</span><span class="dpill">Social Media Branding Templates</span><span class="dpill">Visual Identity Mini-Kit</span><span class="dpill">Voice & Vibe Guide</span></div>
  </div>
</section>
<section class="final">
  <div class="glow"></div>
  <div class="wrap">
    <h2 class="rv">Take this course. Or take everything.</h2>
    <p class="rv">This course: <span class="price-ph" style="border-color:var(--gold-bright);color:var(--gold-bright);background:rgba(212,169,78,.12)">$PRICE</span> one-time. Every course plus weekly coaching: <span class="price-ph" style="border-color:var(--gold-bright);color:var(--gold-bright);background:rgba(212,169,78,.12)">$PRICE</span>/month.</p>
    <a href="#" class="btn btn-gold rv" style="margin-right:12px">Enroll in Personal Branding For Realtors</a>
    <a href="club.html" class="btn btn-ghost rv" style="border-color:var(--gold-bright);color:var(--gold-bright)">Join the Club</a>
  </div>
</section>
<footer>
  <div class="wrap">
    <div class="foot-grid">
      <div>
        <div class="foot-logo"><img src="https://i0.wp.com/luxuryleasingacademy.com/wp-content/uploads/brizy/imgs/Logo-Light-Text-Transparent-172x172x0x0x172x172x1752458947.png?w=1400&ssl=1" alt="Luxury Leasing Academy"></div>
        <div class="foot-tag">Treat rentals like a real business, not a side hustle.</div>
        <div style="color:var(--gold-bright);font-weight:600;font-size:13px">#BetterAgentsWin</div>
      </div>
      <div><h4>Learn</h4><a href="courses.html">Courses</a><a href="club.html">Elite Leasing Club</a><a href="ebook.html">Free E-Book</a><a href="thanks.html">The Playbook</a></div>
      <div><h4>About</h4><a href="meet-matty.html">Meet Matty</a><a href="ebook.html">The Lease Up</a><a href="mailto:matty@luxuryleasingacademy.com">Contact</a></div>
      <div><h4>Students</h4><a href="https://portal.luxuryleasingacademy.com">Student Login</a><a href="#">Terms</a><a href="#">Privacy</a></div>
    </div>
    <div class="foot-bottom"><div>&copy; 2026 Luxury Leasing Academy, LLC</div><div>Chicago, IL</div></div>
  </div>
</footer>
<script>
const burger=document.getElementById('burger'),mm=document.getElementById('mobileMenu');
if(burger){burger.addEventListener('click',()=>{const o=mm.classList.toggle('open');burger.classList.toggle('open',o);burger.setAttribute('aria-expanded',o)});
mm.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>{mm.classList.remove('open');burger.classList.remove('open')}));}
const io=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target)}}),{threshold:.12});
document.querySelectorAll('.rv').forEach(el=>io.observe(el));
document.querySelectorAll('form[data-optin]').forEach(f=>f.addEventListener('submit',e=>{e.preventDefault();window.location.href='thanks.html'}));
</script>
</body>
</html>